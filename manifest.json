{
  "manifest_version": 3,
  "name": "YouTube Cleaner — Hide Feed & Recommendations",
  "version": "1.0.0",
  "description": "Hide YouTube home feed, Shorts, side recommendations, end cards, and more. Toggle via popup.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["*://*.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Cleaner"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "css": ["styles.css"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
